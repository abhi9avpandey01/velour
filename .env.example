# ──────────────────────────────────────────────────────────────
# Velour — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────
SECRET_KEY=change-me-in-production

# ── PostgreSQL ────────────────────────────────────
POSTGRES_USER=velour
POSTGRES_PASSWORD=velour_secret
POSTGRES_DB=velour
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://velour:velour_secret@postgres:5432/velour

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Supabase ──────────────────────────────────────
SUPABASE_URL=http://localhost:8000
SUPABASE_KEY=your-service-role-key
SUPABASE_BUCKET=wardrobe

# ── xAI (Grok) ──────────────────────────────────────
XAI_API_KEY=xai-your-api-key

# ── JWT ───────────────────────────────────────────
JWT_SECRET_KEY=jwt-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_GENERAL=60/minute

# ── FastAPI ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000

# ── Next.js ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
